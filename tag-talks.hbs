{{!< default}}

<main class="site-main">

    {{#tag}}
    <section class="taxonomy">

        {{#if feature_image}}
            <div class="taxonomy-media u-placeholder square">
                <img class="u-object-fit" src="{{img_url feature_image size="s"}}" alt="{{name}}">
            </div>
        {{/if}}

        <header class="single-header gh-canvas">
            <h1 class="single-title">{{name}}</h1>
            {{#if description}}
                <div class="single-excerpt">{{description}}</div>
            {{/if}}
        </header>

    </section>
    {{/tag}}

    <div class="post-feed expanded gh-feed gh-canvas">
        {{#foreach posts}}
            {{> "loop-talks"}}
        {{/foreach}}
    </div>

    {{pagination}}

</main>

<script>
    document.querySelectorAll('.talk-title-split').forEach(function (el) {
        var text = el.textContent;
        var sepIndex = text.indexOf(' — ');
        if (sepIndex === -1) return;

        var occasion = text.slice(0, sepIndex);
        var name = text.slice(sepIndex + 3);

        el.textContent = '';

        var occasionEl = document.createElement('span');
        occasionEl.className = 'talk-occasion';
        occasionEl.textContent = occasion;

        var nameEl = document.createElement('span');
        nameEl.className = 'talk-name';
        nameEl.textContent = name;

        el.appendChild(occasionEl);
        el.appendChild(nameEl);
    });
</script>
