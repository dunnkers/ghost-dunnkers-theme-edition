{{!< default}}

<main class="site-main">

    {{#tag}}
    <section class="taxonomy">

        {{#if feature_image}}
            <div class="taxonomy-media u-placeholder square">
                <img class="u-object-fit" src="{{img_url feature_image size="s"}}" alt="{{name}}">
            </div>
        {{/if}}

        <header class="single-header gh-canvas">
            <h1 class="single-title">{{name}}</h1>
            {{#if description}}
                <div class="single-excerpt">{{description}}</div>
            {{/if}}
        </header>

    </section>
    {{/tag}}

    <div class="post-feed expanded gh-feed gh-canvas">
        {{#foreach posts}}
            {{> "loop-talks"}}
        {{/foreach}}
    </div>

    {{pagination}}

</main>

<script>
    document.querySelectorAll('.feed').forEach(function (article) {
        var sourceEl = article.querySelector('.talk-meta-source');
        if (!sourceEl) return;

        var text = sourceEl.textContent;
        var newlineIndex = text.indexOf('\n');
        var firstLine = newlineIndex === -1 ? text : text.slice(0, newlineIndex);
        var content = newlineIndex === -1 ? '' : text.slice(newlineIndex + 1).trim();
        var location = firstLine.replace(/\s*—\s*$/, '').trim();

        if (content) {
            var nameEl = document.createElement('div');
            nameEl.className = 'talk-name';
            nameEl.textContent = content;
            sourceEl.replaceWith(nameEl);
        } else {
            sourceEl.remove();
        }

        if (location) {
            var dateEl = article.querySelector('.feed-date');
            var confEl = document.createElement('div');
            confEl.className = 'feed-conference';
            confEl.textContent = location;
            dateEl.insertAdjacentElement('afterend', confEl);
        }
    });
</script>
