<article class="feed {{post_class}}" data-month="{{date format="MMMM YYYY"}}">

    <div class="feed-image u-placeholder rectangle">
        {{#if feature_image}}
            <img
                class="u-object-fit"
                srcset="{{> "srcset"}}"
                sizes="(min-width: 576px) 160px, 90vw"
                src="{{img_url feature_image size="m"}}"
                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                loading="lazy"
            >
        {{/if}}
    </div>

    <div class="feed-wrapper">
        <h2 class="feed-title">{{title}}</h2>
        {{#if custom_excerpt}}
            <div class="feed-conference">{{custom_excerpt}}</div>
        {{/if}}
        <div class="feed-right">
            <time class="feed-date" datetime="{{date format="YYYY-MM-DD"}}">
                {{date published_at format="DD MMM YYYY"}}
            </time>
            <div class="feed-visibility feed-visibility-{{visibility}}">
                {{> "icons/star"}}
            </div>
            <div class="feed-icon">
                {{> "icons/chevron-right"}}
            </div>
        </div>
    </div>

    <a class="u-permalink" href="{{url}}" aria-label="{{title}}"></a>

</article>
